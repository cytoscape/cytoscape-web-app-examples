{
  "include": [
    "src/**/*"
  ],
  "files": [
    "../node_modules/@cytoscape-web/api-types/index.d.ts"
  ],
  "compilerOptions": {
    "typeRoots": [
      "./node_modules/@types"
    ],
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "baseUrl": "."
  }
}
