{
  "name": "cytoscape-web-app-examples",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "hello-world",
    "network-statistics",
    "network-workflows",
    "project-template",
    "claude-bridge"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm:dev:*\"",
    "dev:hello-world": "npm run dev -w hello-world",
    "dev:network-statistics": "npm run dev -w network-statistics",
    "dev:network-workflows": "npm run dev -w network-workflows",
    "dev:project-template": "npm run dev -w project-template",
    "dev:claude-bridge": "npm run dev -w claude-bridge",
    "clean": "rm -rf hello-world/dist network-statistics/dist network-workflows/dist project-template/dist claude-bridge/dist",
    "rebuild": "npm run clean && npm run build",
    "deploy": "npm run build && npm run copy-dist",
    "copy-dist": "cp -r hello-world/dist docs/hello-world && cp -r network-statistics/dist docs/network-statistics && cp -r network-workflows/dist docs/network-workflows && cp -r project-template/dist docs/project-template && cp -r claude-bridge/dist docs/claude-bridge"
  },
  "peerDependencies": {
    "@mui/material": "^5.16.7",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@cytoscape-web/api-types": "^1.0.0-beta.2",
    "@emotion/react": "^11.10.4",
    "@emotion/styled": "^11.10.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "clean-webpack-plugin": "^4.0.0",
    "concurrently": "^8.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.2",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
